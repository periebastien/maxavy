# ==============================
# LOCAGAIN — Template .env
# Copier ce fichier en .env et remplir les valeurs
# ==============================

NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/locagain
DB_POOL_MAX=20

JWT_SECRET=
JWT_EXPIRES_IN=7d

ENCRYPTION_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
GOOGLE_BUSINESS_REDIRECT_URI=http://localhost:3000/api/v1/google/callback

GOOGLE_API_KEY=

# Suivi de positionnement (geogrid) — DataForSEO (rang local par point de grille)
# Identifiants API : dashboard DataForSEO → API Access (login = email, password = API password)
RANK_PROVIDER=dataforseo
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# Cadence du cron geogrid (G3) — voir GEOGRID_DESIGN_FR.md §6
GEOGRID_TICK_SECONDS=90
GEOGRID_BATCH_SIZE=20
GEOGRID_CONCURRENCY=20
GEOGRID_SCAN_TIMEOUT_MINUTES=15

# Résilience du cron geogrid (retry + étalement + circuit-breaker) — voir GEOGRID_REFONTE_FR.md §7
GEOGRID_MAX_SCAN_ATTEMPTS=3            # reprises max d'un scan avant échec définitif
GEOGRID_MAX_RUN_ATTEMPTS=2             # reprises max d'un rapport entier (filet de sécurité)
GEOGRID_RETRY_BACKOFF_SCAN=10,30,90    # paliers de backoff scan (minutes, 1 par tentative)
GEOGRID_RETRY_BACKOFF_RUN=30,120       # paliers de backoff run (minutes)
GEOGRID_RETRY_JITTER_MINUTES=5         # fenêtre de jitter déterministe anti-rafale
GEOGRID_RECOVERY_WINDOW_MINUTES=360    # durée max de re-poll gratuit d'un scan partiel
GEOGRID_MAX_POINTS_IN_FLIGHT=800       # plafond de points en vol (protège les 1000 de tasks_ready)
GEOGRID_BREAKER_THRESHOLD=10           # échecs transport consécutifs → pause des lancements
GEOGRID_BREAKER_COOLDOWN_MINUTES=10    # durée de la pause circuit ouvert

EMAIL_PROVIDER=brevo
EMAIL_API_KEY=
EMAIL_FROM=noreply@locagain.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

STORAGE_PATH=/var/www/locagain/storage

# ==============================
# FRONTEND (frontend/.env)
# ==============================
# VITE_GOOGLE_CLIENT_ID=
# VITE_GOOGLE_API_KEY=
# VITE_APP_URL=http://localhost:5173   ← dev
# VITE_APP_URL=https://locagain.com   ← prod (definir dans frontend/.env.production ou avant vite build)
